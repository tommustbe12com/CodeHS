function start(){
    putBall();
    while(frontIsClear()){
        turnLeft();
        while (ballsPresent()) {
            move();
        }
    
        turnRight();
        move();
        createStep();
    }
}
// function for create step
function createStep() {
    turnRight();
    putBall();
    while (frontIsClear()) {
        move();
        putBall();
    }
    turnLeft();
}
